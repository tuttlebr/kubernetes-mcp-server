# Kubernetes MCP deployment settings.
# The deploy script also loads ../.env before this file.

BUILD_IMAGE=true
PUSH_IMAGE=true
DRY_RUN=false

# DevOps agent (optional — omit or leave blank to disable devopsAgent tool)
OPENCODE_BASE_URL=
OPENCODE_API_KEY=
OPENCODE_MODEL=

# HTTP MCP auth. Required by the default Kubernetes deployment.
MCP_AUTH_TOKEN=

# Capability gates. Leave false unless intentionally operating in a trusted environment.
SERVER_READ_ONLY=true
MCP_ENABLE_EXEC=false
MCP_ENABLE_KUBECTL=false
MCP_ENABLE_AGENT_WRITE=false
